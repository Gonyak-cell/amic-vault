# Development-only defaults. Do not put real secrets in this file.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=amic_vault
POSTGRES_USER=amic_vault
POSTGRES_PASSWORD=amic_vault_dev_password
DATABASE_URL=postgres://amic_vault:amic_vault_dev_password@localhost:5432/amic_vault
APP_DATABASE_URL=postgres://vault_app:vault_app_dev_password@localhost:5432/amic_vault

MINIO_ROOT_USER=amic-vault-minio
MINIO_ROOT_PASSWORD=amic-vault-minio-dev-password
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=amic-vault-dev
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=amic-vault-minio
S3_SECRET_ACCESS_KEY=amic-vault-minio-dev-password
DOCUMENT_ALLOWED_EXTENSIONS=pdf,docx,hwpx
DOCUMENT_UPLOAD_MAX_BYTES=209715200

API_PORT=3001
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/v1

# Outlook add-in gates remain fail-closed until an explicit M365 integration approval.
OUTLOOK_ADDIN_ENABLED=false
OUTLOOK_AUTH_EXCHANGE_ENABLED=false
OUTLOOK_GRAPH_ATTACHMENT_ACQUISITION_ENABLED=false
OUTLOOK_SMART_ALERTS_ENABLED=false
OUTLOOK_SEND_FILE_ENABLED=false
