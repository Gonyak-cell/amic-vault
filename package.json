{
  "name": "amic-vault",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22 <23",
    "pnpm": ">=9 <11"
  },
  "scripts": {
    "lint": "turbo run lint --filter='./apps/*' --filter='./packages/*'",
    "typecheck": "turbo run typecheck --filter='./apps/*' --filter='./packages/*'",
    "test": "turbo run test --filter='./apps/*' --filter='./packages/*'",
    "build": "turbo run build --filter='./apps/*' --filter='./packages/*'",
    "check:production-ui-literals": "node tools/quality/check-production-ui-literals.mjs",
    "ui:production-smoke": "node tools/release/check-production-ui-smoke.mjs",
    "check:ui-pr-checklist": "node tools/quality/check-ui-pr-checklist.mjs",
    "backlog:validate": "node tools/backlog/validate-all.mjs",
    "launch:readiness": "node tools/release/check-launch-readiness.mjs",
    "launch:execution": "node tools/release/check-launch-execution.mjs",
    "release:uat": "node tools/release/synthetic-uat-evidence.mjs",
    "release:prod-preflight": "node tools/release/production-release-preflight.mjs",
    "release:smoke": "node tools/release/staging-smoke.mjs",
    "release:dms-smoke": "node tools/release/dms-main-loop-smoke.mjs",
    "release:local-preflight": "node tools/release/local-staging-preflight.mjs",
    "desktop:release-gate": "node tools/release/check-desktop-release-gate.mjs",
    "outlook:deployment:check": "node tools/release/check-outlook-deployment.mjs",
    "outlook:manifest:render": "node tools/release/render-outlook-manifest.mjs",
    "outlook:verification:check": "node tools/release/check-outlook-verification.mjs",
    "outlook:operational:check": "node --experimental-strip-types tools/release/check-outlook-operational.ts",
    "outlook:redaction:check": "node --experimental-strip-types tools/release/check-outlook-redaction.ts --changed",
    "docs:frozen": "node infra/ci/scripts/check-docs-package-frozen.mjs",
    "db:migrate": "node tools/db/migrate.mjs up",
    "db:rollback": "node tools/db/migrate.mjs down 999",
    "db:seed": "node tools/db/seed.mjs",
    "evalset:load": "node tools/evalset/load-evaluation-cases.ts",
    "eval:ai-gate": "node tools/evalset/run-ai-gate-metrics.ts",
    "eval:local-ai": "node tools/evalset/run-local-ai-eval.ts",
    "ai-prep:scan": "node tools/ai/scan-ai-prep-storage.ts",
    "ai-prep:prepare-queue": "pnpm --filter @amic-vault/domain build && pnpm --filter @amic-vault/shared build && pnpm --filter @amic-vault/api build && node apps/api/dist/tools/prepare-ai-prep-queue.js",
    "ai-prep:reprocess-fallbacks": "pnpm --filter @amic-vault/domain build && pnpm --filter @amic-vault/shared build && pnpm --filter @amic-vault/ai build && pnpm --filter @amic-vault/api build && node apps/api/dist/tools/reprocess-ai-prep-fallbacks.js",
    "onedrive:pilot-write": "pnpm --filter @amic-vault/api build && node apps/api/dist/tools/onedrive-pilot-write-runner.js",
    "onedrive:customer-wide-import": "pnpm --filter @amic-vault/api build && node apps/api/dist/tools/onedrive-customer-wide-import-runner.js",
    "onedrive:source-cutover-preflight": "pnpm --filter @amic-vault/api build && node apps/api/dist/tools/onedrive-source-cutover-preflight.js",
    "onedrive:source-cutover-execute": "pnpm --filter @amic-vault/api build && node apps/api/dist/tools/onedrive-source-cutover-execute.js",
    "onedrive:production-preflight": "pnpm --filter @amic-vault/api build && node apps/api/dist/tools/onedrive-production-preflight.js",
    "onedrive:closeout-gate": "pnpm --filter @amic-vault/api build && node apps/api/dist/tools/onedrive-closeout-gate-runner.js",
    "onedrive:production-runtime-target-check": "pnpm --filter @amic-vault/api build && node apps/api/dist/tools/onedrive-production-runtime-target-check.js",
    "onedrive:production-pilot-import": "pnpm --filter @amic-vault/api build && node apps/api/dist/tools/onedrive-production-pilot-import-runner.js",
    "onedrive:production-pilot-closeout": "pnpm --filter @amic-vault/api build && node apps/api/dist/tools/onedrive-production-pilot-closeout-runner.js",
    "onedrive:full-closeout-remediate": "pnpm --filter @amic-vault/api build && node apps/api/dist/tools/onedrive-full-closeout-remediation-runner.js",
    "matter:identity-preflight": "node tools/migration/matter-app-identity-preflight.mjs",
    "matter:canonical-sync": "node tools/migration/matter-app-canonical-upsert-sync.mjs",
    "matter:bridge-closeout": "node tools/migration/matter-app-migration-db-linkage-closeout.mjs",
    "gemma:ai-allowed-pilot": "pnpm --filter @amic-vault/api build && node apps/api/dist/tools/gemma-ai-allowed-pilot-runner.js",
    "gemma:customer-wide": "pnpm --filter @amic-vault/api build && node apps/api/dist/tools/gemma-customer-wide-runner.js",
    "gemma:customer-wide-fallback-closeout": "pnpm --filter @amic-vault/api build && node apps/api/dist/tools/gemma-customer-wide-fallback-closeout-runner.js",
    "gemma:customer-wide-prep": "pnpm --filter @amic-vault/api build && node apps/api/dist/tools/gemma-customer-wide-prep-runner.js",
    "gemma:customer-wide-real-output": "pnpm --filter @amic-vault/ai build && pnpm --filter @amic-vault/api build && node apps/api/dist/tools/gemma-customer-wide-real-output-runner.js",
    "onedrive:import-target-resolution": "node tools/migration/onedrive-import-target-resolution.mjs",
    "bench:local-models": "node tools/bench/run-local-model-bench.ts",
    "eval:contract-gate": "pnpm --filter @amic-vault/domain build && pnpm --filter @amic-vault/shared build && pnpm --filter @amic-vault/api build && node tools/evalset/run-contract-intel-gate.ts",
    "graph:check": "node tools/graph/check-consistency.ts",
    "search:eval:korean": "node tools/search-eval/run-korean-eval.ts",
    "test:integration": "node tools/integration/run.mjs",
    "local-ai:prod-ready": "node tools/release/check-local-ai-prod-ready.mjs",
    "evalset:generate-upload-prep": "node tools/evalset/generate-upload-prep-cases.ts",
    "evalset:seed-local-ai-prep": "node tools/evalset/seed-local-ai-prep-artifacts.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.7",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "eslint": "^9.18.0",
    "node-pg-migrate": "^8.0.4",
    "prettier": "^3.4.2",
    "turbo": "^2.3.4",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "argon2": "^0.44.0",
    "pg": "^8.21.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  }
}
