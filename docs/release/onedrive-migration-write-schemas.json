{
  "schema_version": "2026-06-24.approved-write.v1",
  "status": "pre_write_planning_only",
  "privacy_policy": {
    "repository_allowed": [
      "schema definitions",
      "aggregate counts",
      "approval references",
      "bounded enum values",
      "stable hashes",
      "non-secret operator references",
      "non-secret source lane labels"
    ],
    "repository_forbidden": [
      "document body",
      "OCR text",
      "text excerpts",
      "screenshots exposing source data",
      "unredacted source locations",
      "tokens",
      "cookies",
      "credentials",
      "private tenant values",
      "unbounded Matter app payloads"
    ]
  },
  "enums": {
    "row_state": [
      "approved",
      "archive_only",
      "needs_review",
      "blocked",
      "deferred"
    ],
    "write_action": [
      "planned_create",
      "planned_reuse",
      "created",
      "reused",
      "updated_projection",
      "skipped_idempotent",
      "skipped_archive",
      "blocked",
      "needs_review"
    ],
    "gate_state": [
      "pass",
      "fail",
      "not_applicable",
      "blocked"
    ],
    "quarantine_state": [
      "not_quarantined",
      "projection_upload_blocked",
      "matter_app_remediation_requested",
      "corrected",
      "superseded"
    ],
    "source_mode": [
      "matter_app_api",
      "matter_app_event_projection",
      "vault_projection_only",
      "unconfigured"
    ],
    "blocked_reason_code": [
      "not_approved",
      "archive_only",
      "missing_required_field",
      "missing_evidence_approval",
      "client_ambiguous",
      "matter_code_invalid",
      "matter_code_duplicate",
      "matter_type_unsupported",
      "matter_app_unavailable",
      "matter_app_stale",
      "existing_record_conflict",
      "vault_projection_conflict",
      "idempotency_conflict",
      "receipt_policy_violation",
      "write_contract_missing",
      "vault_projection_only_not_canonical",
      "matter_app_vault_identity_mismatch",
      "source_revision_missing",
      "customer_document_import_attempted"
    ],
    "matter_type_english": [
      "Criminal",
      "Civil",
      "Advisory",
      "M&A"
    ]
  },
  "contracts": {
    "matter_app_client_upsert": {
      "status": "blocked_until_matter_app_write_api_or_approved_event_projection_exists",
      "allowed_source_modes": [
        "matter_app_api",
        "matter_app_event_projection"
      ],
      "forbidden_source_modes": [
        "vault_projection_only",
        "unconfigured"
      ],
      "request_fields": [
        {
          "name": "tenantRef",
          "required": true,
          "privacy": "ref_or_hash"
        },
        {
          "name": "idempotencyKeyHash",
          "required": true,
          "privacy": "hash"
        },
        {
          "name": "clientDisplayName",
          "required": true,
          "privacy": "approved_bounded_label"
        },
        {
          "name": "clientShortName",
          "required": true,
          "privacy": "approved_bounded_label"
        },
        {
          "name": "approvalRef",
          "required": true,
          "privacy": "stable_ref"
        },
        {
          "name": "sourceRevision",
          "required": false,
          "privacy": "stable_ref"
        },
        {
          "name": "migrationApprovalRef",
          "required": false,
          "privacy": "stable_ref"
        },
        {
          "name": "supportingEvidenceRefs",
          "required": true,
          "privacy": "array:stable_ref"
        }
      ],
      "response_fields": [
        {
          "name": "clientId",
          "required": true,
          "privacy": "stable_ref"
        },
        {
          "name": "clientDisplayName",
          "required": true,
          "privacy": "approved_bounded_label"
        },
        {
          "name": "sourceRevision",
          "required": true,
          "privacy": "stable_ref"
        },
        {
          "name": "action",
          "required": true,
          "type": "enum:write_action",
          "privacy": "non_secret_label"
        }
      ],
      "rules": [
        "sourceRevision or migrationApprovalRef is required on request",
        "multiple possible client matches return blocked or needs_review",
        "vault_projection_only is never a production write source"
      ]
    },
    "matter_app_matter_upsert": {
      "status": "blocked_until_matter_app_write_api_or_approved_event_projection_exists",
      "allowed_source_modes": [
        "matter_app_api",
        "matter_app_event_projection"
      ],
      "request_fields": [
        {
          "name": "tenantRef",
          "required": true,
          "privacy": "ref_or_hash"
        },
        {
          "name": "idempotencyKeyHash",
          "required": true,
          "privacy": "hash"
        },
        {
          "name": "clientId",
          "required": true,
          "privacy": "stable_ref"
        },
        {
          "name": "clientDisplayName",
          "required": true,
          "privacy": "approved_bounded_label"
        },
        {
          "name": "matterCode",
          "required": true,
          "max_length": 120,
          "privacy": "approved_bounded_label"
        },
        {
          "name": "matterName",
          "required": true,
          "privacy": "approved_bounded_label"
        },
        {
          "name": "matterTypeEnglish",
          "required": true,
          "type": "enum:matter_type_english",
          "privacy": "enum_value"
        },
        {
          "name": "matterDetailTypeKorean",
          "required": true,
          "privacy": "approved_bounded_label"
        },
        {
          "name": "practiceGroup",
          "required": false,
          "privacy": "approved_bounded_label"
        },
        {
          "name": "responsibleLawyer",
          "required": false,
          "privacy": "ref_or_hash"
        },
        {
          "name": "openedAt",
          "required": false,
          "format": "date-time",
          "privacy": "timestamp"
        },
        {
          "name": "closedAt",
          "required": false,
          "format": "date-time",
          "privacy": "timestamp"
        },
        {
          "name": "sourceRevision",
          "required": false,
          "privacy": "stable_ref"
        },
        {
          "name": "migrationApprovalRef",
          "required": false,
          "privacy": "stable_ref"
        }
      ],
      "response_fields": [
        {
          "name": "matterAppMatterId",
          "required": true,
          "privacy": "stable_ref"
        },
        {
          "name": "matterCode",
          "required": true,
          "max_length": 120,
          "privacy": "approved_bounded_label"
        },
        {
          "name": "clientId",
          "required": true,
          "privacy": "stable_ref"
        },
        {
          "name": "sourceRevision",
          "required": true,
          "privacy": "stable_ref"
        },
        {
          "name": "action",
          "required": true,
          "type": "enum:write_action",
          "privacy": "non_secret_label"
        }
      ],
      "rules": [
        "matterCode must equal clientShortName + '/' + matterTypeEnglish + '/' + matterDetailTypeKorean",
        "matterCode must be unique in tenant scope",
        "response identity mismatch blocks Vault projection sync"
      ]
    },
    "vault_projection_sync": {
      "status": "projection_only_after_matter_app_canonical_result",
      "input_fields": [
        "matterAppMatterId",
        "matterCode",
        "matterName",
        "clientId",
        "clientDisplayName",
        "matterTypeEnglish",
        "matterDetailTypeKorean",
        "status",
        "practiceGroup",
        "responsibleLawyer",
        "openedAt",
        "closedAt",
        "sourceRevision",
        "sourceUpdatedAt"
      ],
      "rules": [
        "projection_is_canonical must be false",
        "vault_projection_only must not be accepted as production canonical source",
        "Matter app and Vault projection identity mismatch fails",
        "document rows, file objects, OCR text, raw paths, and customer document import are forbidden"
      ]
    }
  },
