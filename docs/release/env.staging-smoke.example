# AMIC Vault staging smoke environment template
#
# Copy values into an approved secret manager or local shell environment.
# Do not commit real staging endpoints, passwords, cookies, private URLs, tokens,
# customer data, or provider screenshots to this repository.

# Public references only. Prefer an evidence ref instead of a private URL in
# committed artifacts.
SMOKE_TARGET_REF=LRB-002-STAGING-ENDPOINT-REF
RELEASE_SHA=9e346d9e48c962448bcccbbef9e30d9c3e468e4f

# Runtime endpoints. Use actual values only outside the repository.
WEB_BASE_URL=https://staging.example.invalid
API_BASE_URL=https://staging-api.example.invalid/v1

# Primary synthetic user. Values must come from an approved non-production
# credential source. Tenant id/slug are optional for email-only login and should
# be set only when the smoke identity is intentionally tenant-disambiguated.
SMOKE_TENANT_ID=
SMOKE_TENANT_SLUG=
SMOKE_EMAIL=
SMOKE_PASSWORD=

# Optional negative-role synthetic user for SMOKE-009. Tenant id is optional
# when the negative smoke identity is unique by email.
SMOKE_NEGATIVE_TENANT_ID=
SMOKE_NEGATIVE_EMAIL=
SMOKE_NEGATIVE_PASSWORD=

# Set to 1 for staging gate evidence so missing authenticated checks fail.
SMOKE_REQUIRE_AUTH=1
SMOKE_TIMEOUT_MS=10000

# DMS main-loop smoke. Run with:
# pnpm release:dms-smoke -- --json
#
# This gate verifies login -> Matter Code source -> matter-scoped upload ->
# document detail -> preview/version -> matter file list -> search ->
# records/audit refs -> negative auth. It must use synthetic or approved canary
# tenant data only. Do not commit real file paths, document titles, Matter refs,
# cookies, tokens, private URLs, customer data, raw prompts, raw source/source
# text, or model responses.
DMS_SMOKE_TARGET_REF=LRB-002-DMS-SMOKE-REF
DMS_SMOKE_API_BASE_URL=https://staging-api.example.invalid/v1
DMS_SMOKE_TENANT_ID=
DMS_SMOKE_TENANT_SLUG=
DMS_SMOKE_EMAIL=
DMS_SMOKE_PASSWORD=
DMS_SMOKE_NEGATIVE_TENANT_ID=
DMS_SMOKE_NEGATIVE_TENANT_SLUG=
DMS_SMOKE_NEGATIVE_EMAIL=
DMS_SMOKE_NEGATIVE_PASSWORD=

# Preferred staging/prod mode: provide an approved Matter ref. The script will
# fail closed if neither this nor approved synthetic creation is configured.
DMS_SMOKE_MATTER_ID=

# Local/dev mode may create a synthetic client and matter with --local.
# Staging/prod synthetic creation requires explicit approval outside this file:
# DMS_SMOKE_CREATE_SYNTHETIC=1 and DMS_SMOKE_SYNTHETIC_APPROVED=1.
DMS_SMOKE_CREATE_SYNTHETIC=0
DMS_SMOKE_SYNTHETIC_APPROVED=0
DMS_SMOKE_CLIENT_ID=

# Optional approved fixture. If omitted, the script uses a tiny synthetic PDF.
DMS_SMOKE_FILE_PATH=
DMS_SMOKE_REQUIRE_AUTH=1
DMS_SMOKE_TIMEOUT_MS=10000
DMS_SMOKE_POLL_ATTEMPTS=12
DMS_SMOKE_POLL_DELAY_MS=1000

# Keep this 0 for release signoff. Set to 1 only for local diagnostics where
# search/index workers are intentionally not running; it does not satisfy
# DMS-UX-801 production evidence.
DMS_SMOKE_ALLOW_INDEX_PENDING=0
DMS_SMOKE_ALLOW_PREVIEW_UNAVAILABLE=1
